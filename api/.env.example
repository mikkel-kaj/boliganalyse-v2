# Supabase (server-to-server, service-role key only)
SUPABASE_URL=https://supabase.dev.boliganalyse.ai
SUPABASE_SERVICE_ROLE_KEY=

# Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=8000

# Firecrawl (fallback scraper)
FIRECRAWL_API_KEY=

# Feature flags
ENABLE_DST_TOOLS=true

# CORS — comma-separated list of allowed origins
# Dev: http://localhost:8080
# Prod: https://boliganalyse.ai,https://dev.boliganalyse.ai
CORS_ORIGINS=http://localhost:8080

# Logging
LOG_LEVEL=info
