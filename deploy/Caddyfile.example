# The supabase compose stack ships its own Caddy container that mounts
# /opt/supabase-stack/volumes/proxy/caddy/Caddyfile. We DO NOT install
# Caddy as a system service — append the api block below into the
# existing Caddyfile inside that mount, then reload via:
#
#   docker exec supabase-caddy caddy reload --config /etc/caddy/Caddyfile
#
# The supabase block (using {$PROXY_DOMAIN}) is provided by upstream
# and serves Studio + Kong-routed APIs at https://supabase.<domain>.
# Don't replace it; just add the block below.

# FastAPI listing analysis service.
# `flush_interval -1` keeps SSE streams flowing without buffering — without
# it the frontend's EventSource sees status updates batched at end-of-stream.
api.dev.boliganalyse.ai {
    reverse_proxy api:8000 {
        flush_interval -1
    }

    header -server
}

# Frontend SPA served from the volume mount declared in
# deploy/docker-compose.app.yml.
dev.boliganalyse.ai {
    root * /var/www/app
    try_files {path} /index.html
    file_server
    encode gzip

    # Long-lived cache for hashed asset filenames; SPA shell stays revalidated.
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    header /index.html Cache-Control "no-cache"

    header -server
}
