# Drop this on the Hetzner box at /etc/caddy/Caddyfile after installing
# Caddy. Caddy handles TLS automatically via Let's Encrypt.
#
#   sudo apt-get install -y caddy
#   sudo nano /etc/caddy/Caddyfile   # paste contents, edit hostnames
#   sudo systemctl reload caddy
#
# Replace your-domain.example with your actual domain. DNS A records for
# all subdomains must point to this server before reload.

# Supabase API + Studio.
supabase.your-domain.example {
    reverse_proxy localhost:8000
}

# FastAPI listing analysis service.
# `flush_interval -1` keeps SSE streams flowing without buffering — without
# it the frontend's EventSource sees status updates in batches at end-of-stream.
api.your-domain.example {
    reverse_proxy localhost:8001 {
        flush_interval -1
    }
}

# Frontend, if you serve it from this box.
# Build the SPA locally with `npm run build`, scp `dist/` to /var/www/app/,
# and uncomment this block.
#
# app.your-domain.example {
#     root * /var/www/app
#     try_files {path} /index.html
#     file_server
#     encode gzip
# }
