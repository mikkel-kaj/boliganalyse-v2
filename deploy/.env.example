# =============================================================================
# Self-hosted Supabase + boliganalyse-ai — server env
# Copy this to /opt/supabase-stack/.env on the Hetzner box and fill in values.
# Never commit the filled-in version.
# =============================================================================

# ---- Postgres ---------------------------------------------------------------
# Strong random password. Used by every internal service.
POSTGRES_PASSWORD=CHANGE_ME_long_random_string
# Default db name. Leave as-is unless you have a reason.
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_HOST=db

# ---- JWT --------------------------------------------------------------------
# 32+ char random string. The ANON_KEY and SERVICE_ROLE_KEY below are JWTs
# signed with this secret. Use deploy/scripts/generate-keys.mjs to derive
# all three from a fresh secret.
JWT_SECRET=CHANGE_ME_at_least_32_chars_random
JWT_EXPIRY=3600

# Public anon JWT — used by the frontend.
ANON_KEY=CHANGE_ME_paste_from_generate_keys
# Secret service-role JWT — used only by server-side code (edge functions).
SERVICE_ROLE_KEY=CHANGE_ME_paste_from_generate_keys

# ---- API + Studio URLs ------------------------------------------------------
# Public URL the frontend hits. Behind Caddy this is your https hostname.
SITE_URL=https://app.your-domain.example
API_EXTERNAL_URL=https://supabase.your-domain.example
SUPABASE_PUBLIC_URL=https://supabase.your-domain.example

# Internal — leave defaults.
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# ---- Studio (admin UI) auth -------------------------------------------------
# Basic auth in front of Studio. Set both to something strong.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGE_ME_strong

# ---- SMTP (auth emails) — optional but needed for password reset etc. -------
SMTP_HOST=smtp.your-provider.example
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME
SMTP_SENDER_NAME=Boliganalyse
SMTP_ADMIN_EMAIL=admin@your-domain.example

# ---- Auth providers / behaviour --------------------------------------------
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
DISABLE_SIGNUP=false

# ---- App secrets — shared by FastAPI api/ and the legacy edge function ----
# OPENAI_API_KEY is unused by the FastAPI server; kept while the edge function
# still exists. Once the edge function is removed (phase-2 task #9), drop it.
OPENAI_API_KEY=sk-CHANGE_ME
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=8000
FIRECRAWL_API_KEY=fc-CHANGE_ME

# Comma-separated origins the api server will accept CORS preflights from.
# Production: https://boliganalyse.ai,https://dev.boliganalyse.ai
CORS_ORIGINS=https://dev.boliganalyse.ai

# DST (Danmarks Statistik) tool-calling chain. Default ON for the api server
# now that the wall-clock cap is gone. The legacy edge function is forced OFF
# in docker-compose.app.yml regardless of this value.
ENABLE_DST_TOOLS=true

LOG_LEVEL=info

# ---- Misc -------------------------------------------------------------------
# PostgREST exposes these schemas. `app` holds the listing + feedback tables;
# only the FastAPI server (with the service-role key) reads/writes them.
PGRST_DB_SCHEMAS=public,storage,graphql_public,app
