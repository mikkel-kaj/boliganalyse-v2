# Frontend env. Copy to .env.local for `npm run dev`, set the same vars in
# Netlify (or whichever host you use) for production builds.

# Self-hosted Supabase API URL — public hostname behind Caddy.
VITE_SUPABASE_URL=https://supabase.your-domain.example

# Anon JWT from /opt/supabase-stack/.env on the server.
VITE_SUPABASE_ANON_KEY=eyJ...
